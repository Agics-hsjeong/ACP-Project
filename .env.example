# PostgreSQL
POSTGRES_DB=acp
POSTGRES_USER=acp
POSTGRES_PASSWORD=acp

# MinIO
MINIO_ROOT_USER=acp
MINIO_ROOT_PASSWORD=acpminio123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=acp
MINIO_SECRET_KEY=acpminio123
MINIO_BUCKET=acp
MINIO_SECURE=0

# Archive — /ARCHIVE/acp/ (DoRaGi-LM 과 동일 구조)
ARCHIVE_PROJECT=acp
ARCHIVE_BASE=/ARCHIVE/acp
ARCHIVE_ROOT=/ARCHIVE/acp/data
ARCHIVE_MODELS_ROOT=/ARCHIVE/acp/models
ARCHIVE_PREFIX=data

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBED_MODEL=gemini-embedding-2
GEMINI_LLM_MODEL=gemini-3.1-flash-lite
GEMINI_EMBED_DIM=768

# Firebase Auth (백엔드 ID 토큰 검증)
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 JSON
FIREBASE_PROJECT_ID=aicharacterplayground
FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json

# LAN 접속 (같은 Wi‑Fi 폰·다른 PC)
# Firebase는 IP 직접 등록이 UI에서 막혀 보일 수 있음 → 아래 acp.local 방식 권장
LAN_TRUSTED_ORIGINS=http://192.168.0.63:28433,http://acp.local:28433
# 폰/PC hosts: 192.168.0.63 acp.local → Firebase 승인 도메인에 acp.local 추가
ACP_LAN_HOST=acp.local

# Firebase Web (프론트 Google 로그인)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=
